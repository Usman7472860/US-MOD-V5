# Server
PORT=3001
FRONTEND_URL=http://localhost:3000

# JWT Secret - change this to a long random string!
JWT_SECRET=usbot_super_secret_key_change_this_in_production_2024

# Sessions folder (Railway Volume mount karke yahan point karo)
